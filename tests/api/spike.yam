scenarios:
    api_test:
        requests:
            - url: http://localhost:8080/get
                method: GET
                label: Spike Test

execution:
    - concurrency: 1
        hold-for: 5s
        scenario: api_test

    - concurrency: 200
        hold-for: 10s
        scenario: api_test

    - concurrency: 1
        hold-for: 5s
        scenario: api_test

reporting:
    - module: console
    - module: final-stats