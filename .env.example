# Klucze API giełdy (Binance, Kraken itp.) — skopiuj do .env i wypełnij
EXCHANGE_API_KEY=twoj_klucz_api
EXCHANGE_API_SECRET=twoj_sekret_api

# Telegram bot (opcjonalnie)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# BlazeMeter (NIE dodawaj tokenu do repo — przechowuj w ~/.bzt-rc)
# BLAZEMETER_TOKEN=
# BLAZEMETER_WORKSPACE_ID=2269510

# Azure Functions
AZURE_STORAGE_CONNECTION_STRING=
AZURE_FUNCTIONS_KEY=

# Taurus load test thresholds
LOAD_TEST_CONCURRENCY=10
LOAD_TEST_DURATION_SECONDS=120
LOAD_TEST_TARGET_URL=https://jsonplaceholder.typicode.com
