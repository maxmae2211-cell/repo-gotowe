{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Windows: Zainstaluj wymagania systemowe (Java + VC++)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/install-prerequisites.ps1"
            ],
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Taurus: Health Check",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "health"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: Standard API Run",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "standard"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: JMeter + Java8",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "jmeter-java8"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: Full Pipeline",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "pipeline"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: Standard Advanced Config",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "standard",
                "-Config",
                "test-advanced.yml"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: Health Advanced Config",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "health",
                "-Config",
                "test-advanced.yml"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: JMeter + Java8 Advanced Config",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "jmeter-java8",
                "-Config",
                "test-advanced.yml"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Taurus: Full Pipeline Advanced Config",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/run-taurus.ps1",
                "-Mode",
                "pipeline",
                "-Config",
                "test-advanced.yml"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Auto: gitignore commit+push",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\auto-gitignore.ps1",
                "-Branch",
                "qq",
                "-Message",
                "Update .gitignore"
            ],
            "problemMatcher": []
        },
        {
            "label": "PR: open compare qq -> main",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Start-Process 'https://github.com/maxmae2211-cell/repo-gotowe/compare/main...qq'"
            ],
            "problemMatcher": []
        },
        {
            "label": "Auto: gitignore commit+push + open PR",
            "dependsOn": [
                "Auto: gitignore commit+push",
                "PR: open compare qq -> main"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "git status",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/git-status.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "Auto: commit + push wszystko",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "git add -A; git commit -m 'Automatyczny commit przez task'; git push origin qq"
            ],
            "problemMatcher": []
        },
        {
            "label": "git branch",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/git-branch.ps1"
            ],
            "problemMatcher": []
        },
        {
            "type": "func",
            "label": "func: host start",
            "command": "host start",
            "problemMatcher": "$func-node-watch",
            "isBackground": true,
            "dependsOn": "npm install (functions)"
        },
        {
            "type": "shell",
            "label": "npm install (functions)",
            "command": "npm install"
        },
        {
            "type": "shell",
            "label": "npm prune (functions)",
            "command": "npm prune --production",
            "problemMatcher": []
        },
        {
            "type": "docker-build",
            "label": "docker-build",
            "platform": "node",
            "dockerBuild": {
                "dockerfile": "${workspaceFolder}/Dockerfile",
                "context": "${workspaceFolder}",
                "pull": true
            }
        },
        {
            "type": "docker-run",
            "label": "docker-run: release",
            "dependsOn": [
                "docker-build"
            ],
            "platform": "node"
        },
        {
            "type": "docker-run",
            "label": "docker-run: debug",
            "dependsOn": [
                "docker-build"
            ],
            "dockerRun": {
                "env": {
                    "DEBUG": "*",
                    "NODE_ENV": "development"
                }
            },
            "node": {
                "enableDebugging": true
            }
        }
    ]
}