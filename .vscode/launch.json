                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Uruchom przeglądarkę Chrome względem hosta lokalnego",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}